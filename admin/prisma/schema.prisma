generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  ADMIN_ACCOUNTING
  DRIVER
}

enum InquiryStatus {
  NEW
  ACCEPTED
  REJECTED
}

enum OrderStatus {
  OPEN
  ASSIGNED
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  INVOICE
  CASH
}

enum CustomerType {
  PRIVATE
  BUSINESS
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum IncomingInvoiceStatus {
  PENDING
  PAID
  OVERDUE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(DRIVER)
  phone        String?
  vehiclePlate String?
  maxDistanceKm Int?
  initials     String?  @unique
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders         Order[]  @relation("driver")
  secondaryOrders Order[] @relation("secondDriver")
  vacations      Vacation[]

  @@map("users")
}

model Company {
  id                   String  @id @default(cuid())
  name                 String
  address              String
  city                 String
  zip                  String
  taxNumber            String?
  email                String?
  phone                String?
  bankName             String?
  bankIban             String?
  bankBic              String?
  invoicePrefix        String
  invoiceNumberCurrent Int     @default(0)
  quotePrefix          String
  quoteNumberCurrent   Int     @default(0)
  isKleinunternehmer   Boolean @default(true)
  logoUrl              String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  orders           Order[]
  quotes           Quote[]
  invoices         Invoice[]
  incomingInvoices IncomingInvoice[]
  bankConnections  BankConnection[]
  bankTransactions BankTransaction[]

  @@map("companies")
}

model Customer {
  id           String       @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  customerType CustomerType @default(PRIVATE)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders    Order[]
  inquiries Inquiry[]

  @@map("customers")
}

model Inquiry {
  id              String        @id @default(cuid())
  customerId      String?
  customerName    String
  customerEmail   String
  customerPhone   String?
  customerType    CustomerType  @default(PRIVATE)
  eventDate       DateTime
  eventType       String
  locationName    String
  locationAddress String
  locationLat     Float?
  locationLng     Float?
  distanceKm      Float?
  extras          String[]      @default([])
  comments        String?
  status          InquiryStatus @default(NEW)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  customer Customer? @relation(fields: [customerId], references: [id])
  order    Order?

  @@map("inquiries")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     Int           @default(autoincrement())
  inquiryId       String        @unique
  customerId      String?
  companyId       String
  driverId        String?
  secondDriverId  String?
  paymentMethod   PaymentMethod @default(INVOICE)
  status          OrderStatus   @default(OPEN)
  price           Float
  travelCost      Float?
  boxPrice        Float?
  extrasCost      Float?
  setupCost       Float?
  materialCost    Float?
  discount        Float?
  discountType    String?       @default("AMOUNT")
  profit          Float?
  extras          String[]      @default([])
  notes           String?
  internalNotes   String?
  eventDate       DateTime
  eventType       String
  locationName    String
  locationAddress String
  customerName    String
  customerEmail   String
  customerPhone   String?
  setupDate       DateTime?
  setupTime       String?
  teardownDate    DateTime?
  teardownTime    String?
  confirmed       Boolean       @default(false)
  designReady     Boolean       @default(false)
  planned         Boolean       @default(false)
  paid            Boolean       @default(false)
  graphicUrl      String?
  images          String[]      @default([])
  confirmationToken String?     @unique @default(cuid())
  confirmedByCustomerAt DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  inquiry       Inquiry   @relation(fields: [inquiryId], references: [id])
  customer      Customer? @relation(fields: [customerId], references: [id])
  company       Company  @relation(fields: [companyId], references: [id])
  driver        User?    @relation("driver", fields: [driverId], references: [id])
  secondDriver  User?    @relation("secondDriver", fields: [secondDriverId], references: [id])
  quotes        Quote[]
  invoices      Invoice[]

  @@map("orders")
}

model Vacation {
  id        String   @id @default(cuid())
  driverId  String
  startDate DateTime
  endDate   DateTime
  note      String?
  createdAt DateTime @default(now())

  driver User @relation(fields: [driverId], references: [id])

  @@map("vacations")
}

model Quote {
  id          String      @id @default(cuid())
  orderId     String
  companyId   String
  quoteNumber String      @unique
  items       Json
  totalAmount Float
  status      QuoteStatus @default(DRAFT)
  validUntil  DateTime
  pdfUrl      String?
  sentAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  order   Order   @relation(fields: [orderId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  @@map("quotes")
}

model Invoice {
  id            String        @id @default(cuid())
  orderId       String
  companyId     String
  invoiceNumber String        @unique
  items         Json
  totalAmount   Float
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime
  paidAt        DateTime?
  pdfUrl        String?
  sentAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  order            Order            @relation(fields: [orderId], references: [id])
  company          Company          @relation(fields: [companyId], references: [id])
  bankTransactions BankTransaction[]

  @@map("invoices")
}

model IncomingInvoice {
  id            String                @id @default(cuid())
  companyId     String
  vendor        String
  invoiceNumber String?
  amount        Float
  dueDate       DateTime?
  status        IncomingInvoiceStatus @default(PENDING)
  category      String?
  pdfUrl        String?
  ocrData       Json?
  paidAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  company          Company          @relation(fields: [companyId], references: [id])
  bankTransactions BankTransaction[]

  @@map("incoming_invoices")
}

model BankTransaction {
  id                       String   @id @default(cuid())
  companyId                String
  date                     DateTime
  amount                   Float
  reference                String?
  counterpartName          String?
  counterpartIban          String?
  matchedInvoiceId         String?
  matchedIncomingInvoiceId String?
  isReconciled             Boolean  @default(false)
  rawData                  Json?
  createdAt                DateTime @default(now())

  company         Company          @relation(fields: [companyId], references: [id])
  matchedInvoice  Invoice?         @relation(fields: [matchedInvoiceId], references: [id])
  matchedIncoming IncomingInvoice? @relation(fields: [matchedIncomingInvoiceId], references: [id])

  @@map("bank_transactions")
}

model Location {
  id              String   @id @default(cuid())
  name            String
  street          String?
  zip             String?
  city            String?
  distanceKm      Float?
  notes           String?
  usageCount      Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([name, city])
  @@map("locations")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

model TravelPricingTier {
  id                 String @id @default(cuid())
  distanceKm         Int    @unique
  driverCompensation Float
  customerPrice      Float

  @@map("travel_pricing_tiers")
}

model BankConnection {
  id           String    @id @default(cuid())
  companyId    String
  bankName     String
  bankUrl      String
  bankCode     String
  username     String
  encryptedPin String
  lastSync     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id])

  @@map("bank_connections")
}
